rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // By default, deny all reads and writes
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Allow public read access to buses, destinations, teachers, and lost items
    match /buses/{busId} {
      allow get, list: if true;
      allow write: if request.auth != null; // Only authenticated users can write
    }
    
    match /destinations/{destinationId} {
      allow get, list: if true;
      allow write: if request.auth != null;
    }
    
    match /teachers/{teacherId} {
      allow get, list: if true;
      allow write: if request.auth != null;
    }
    
    match /lostItems/{itemId} {
      allow get, list: if true;
      allow write: if true; // Allow anyone to add/update lost items
    }

    // Students can be created by anyone, but only read/updated by authenticated users.
    match /students/{studentId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
    
    // Routes can only be managed by authenticated users.
    match /routes/{routeId} {
      allow read, list, write: if request.auth != null;
    }
    
    // Subcollections
    match /routes/{routeId}/{collection}/{docId} {
        allow read, write: if request.auth != null;
    }

    // Suggested destinations can be created by anyone, but only read/deleted by authenticated users.
    match /suggestedDestinations/{destinationId} {
        allow create: if true;
        allow read, delete: if request.auth != null;
    }
  }
}
