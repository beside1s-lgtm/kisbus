
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow read/write access to all documents for any user, authenticated or not.
    // This is a very permissive rule suitable for rapid prototyping or internal-only apps
    // where data security is not a primary concern.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
